{
  "name": "react-counter",
  "homepage": "https://harshachouhan2016.github.io/counter-on-react",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "tailwind": "npx tailwindcss -i src/input.css -o src/output.css --watch",
    "build": "npx tailwindcss -i src/input.css -o src/output.css && react-scripts build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19"
  }
}
